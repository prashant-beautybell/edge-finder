# Session pooler port 5432 with connection_limit=1 (required for Prisma + Supabase).
# Do NOT use port 6543 — it causes pool timeouts.
DATABASE_URL="postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require&connection_limit=1"
DIRECT_URL="postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require"

# On Vercel, DATABASE_URL is optional if you use Supabase integration names:
# EDGE_FINDER_POSTGRES_PRISMA_URL (pooled) or EDGE_FINDER_POSTGRES_URL_NON_POOLING (direct)
# Local dev uses prisma/dev.db automatically when the file exists (fast).
# Set USE_LOCAL_DB=false to force Supabase during development.
# USE_LOCAL_DB=true

# Historical CSV directory (defaults to RacingFormBook export path)
HISTORICAL_DATA_DIR="/Users/prashanttripathi/Downloads/RacingFormBookDatabase/RacingFormBook_exported"

# Betfair Exchange API — required for live Exchange prices
# Get a free delayed app key at https://developer.betfair.com/
BETFAIR_APP_KEY=
BETFAIR_USERNAME=
BETFAIR_PASSWORD=
# Local certificate files (optional — for automated login)
BETFAIR_CERT_PATH=./certs/betfair.crt
BETFAIR_KEY_PATH=./certs/betfair.key
# Vercel/serverless: paste full PEM contents (or base64) — required on Vercel
# BETFAIR_CERT_PEM="-----BEGIN CERTIFICATE-----\n..."
# BETFAIR_KEY_PEM="-----BEGIN RSA PRIVATE KEY-----\n..."

# Notifications (Phase 7)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Algorithm config
DEFAULT_JK_THRESHOLD=0
DEFAULT_STAKE=1000
SP_CAP=2.50
MIN_WEIGHT_LBS=122
MIN_FIELD_SIZE=6
MAX_FIELD_SIZE=12
TARGET_DISTANCES=6f,7f,1m

# Football database (separate SQLite file locally: prisma/football.db)
# FOOTBALL_DATABASE_URL="file:./prisma/football.db"

# Football edge scan
FOOTBALL_EDGE_MAX_PRICE=2.5

# App
NODE_ENV=development
PORT=3000
