{
  "name": "racing-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "dev:clean": "npm run db:setup:sqlite && npm run db:setup:football && rm -rf .next && next dev",
    "build": "prisma generate && prisma generate --schema=prisma/schema.sqlite.prisma && prisma generate --schema=prisma/schema.football.sqlite.prisma && next build",
    "postinstall": "prisma generate && prisma generate --schema=prisma/schema.sqlite.prisma && prisma generate --schema=prisma/schema.football.sqlite.prisma",
    "start": "next start",
    "lint": "next lint",
    "db:generate": "prisma generate && prisma generate --schema=prisma/schema.sqlite.prisma && prisma generate --schema=prisma/schema.football.sqlite.prisma",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:setup": "prisma db push && tsx scripts/import-historical.ts --year 2024 --clear",
    "db:setup:sqlite": "DATABASE_URL=\"file:./dev.db\" prisma db push --schema=prisma/schema.sqlite.prisma",
    "db:setup:football": "FOOTBALL_DATABASE_URL=\"file:./football.db\" prisma db push --schema=prisma/schema.football.sqlite.prisma",
    "db:migrate:sqlite": "tsx scripts/migrate-sqlite-to-postgres.ts",
    "db:import:all": "tsx scripts/import-historical.ts --clear",
    "import:historical": "tsx scripts/import-historical.ts",
    "import:historical:clear": "tsx scripts/import-historical.ts --clear",
    "test": "vitest run",
    "scheduler": "tsx scripts/scheduler.ts",
    "daily:ingest": "tsx scripts/daily.ts ingest",
    "daily:results-all": "tsx scripts/daily.ts results-all"
  },
  "dependencies": {
    "@base-ui/react": "^1.5.0",
    "@prisma/client": "^5.22.0",
    "@types/node-cron": "^3.0.11",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "csv-parse": "^7.0.0",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.20.0",
    "next": "14.2.35",
    "node-cron": "^4.3.0",
    "react": "^18",
    "react-day-picker": "^10.0.1",
    "react-dom": "^18",
    "recharts": "^3.8.1",
    "shadcn": "^4.11.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "better-sqlite3": "^12.11.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.35",
    "postcss": "^8",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.1",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "vitest": "^4.1.9"
  }
}
